use std::{mem::replace, sync::Arc};

use crate::{
    linter::{self, Linter},
    parser, project, tokenizer,
    types::*,
};

#[derive(Clone, Copy, Debug)]
pub enum BuiltLValue<'a> {
    This(Option<project::ClassRef<'a>>),
    Super(Found<project::Complex<'a>>),
    Parent(Found<project::Complex<'a>>),

    Variable(
        &'a parser::VariableAccess,
        Found<(Option<project::ClassRef<'a>>, &'a Arc<project::Variable>)>,
    ),
    Function(
        &'a parser::FunctionCall,
        Option<project::ClassRef<'a>>,
        Found<&'a project::Function>,
    ),

    Member(
        &'a Box<parser::LValue>,
        &'a parser::VariableAccess,
        Found<(project::ClassRef<'a>, Found<&'a project::Variable>)>,
    ),
    Method(
        &'a Box<parser::LValue>,
        &'a parser::FunctionCall,
        Found<(
            project::ClassRef<'a>,
            Found<OneOf<&'a project::Function, &'a project::Event>>,
        )>,
    ),
    Index(&'a Box<parser::LValue>, &'a Box<parser::Expression>),
    SQLAccess(&'a tokenizer::Token, &'a Box<parser::LValue>),
}

#[derive(Clone, Copy, Debug)]
pub enum Node<'a> {
    VariableDeclaration(&'a project::Variable),
    ScopedVariableDeclaration(&'a project::Variable),
    InstanceVariableDeclaration(&'a project::Variable),
    Label(&'a tokenizer::Token),

    /// Used for both declarations and the headers above definitions
    FunctionHeader(&'a project::FunctionHeader),
    EventHeader(&'a project::EventHeader),

    LValue(&'a Range, BuiltLValue<'a>),
    Expression(&'a parser::Expression),
    Statement(&'a parser::Statement),

    // Basically just wrapped parser::LValueType
    DataType(&'a parser::DataType, Option<Found<project::Complex<'a>>>),
}

struct NodeSearch<'a> {
    pos: &'a Position,
    nodes: Vec<Node<'a>>,

    linter: &'a Linter<'a>,
    scope: &'a linter::Scope<'a>,

    in_sql: bool,
}

impl NodeSearch<'_> {
    fn inside_sql(&mut self, f: impl FnOnce(&mut Self) -> Found<()>) -> Found<()> {
        let prev_in_sql = replace(&mut self.in_sql, true);
        let found = f(self);
        self.in_sql = prev_in_sql;
        found
    }
}

trait NodeSearcher {
    fn search<'a>(&'a self, search: &mut NodeSearch<'a>) -> Found<()>;
}

impl<T: NodeSearcher> NodeSearcher for Arc<T> {
    fn search<'a>(&'a self, search: &mut NodeSearch<'a>) -> Found<()> {
        (**self).search(search)
    }
}

impl<T: NodeSearcher> NodeSearcher for Option<T> {
    fn search<'a>(&'a self, search: &mut NodeSearch<'a>) -> Found<()> {
        if let Some(val) = self {
            val.search(search)?;
        }

        Found::No
    }
}

impl<T: NodeSearcher> NodeSearcher for Vec<T> {
    fn search<'a>(&'a self, search: &mut NodeSearch<'a>) -> Found<()> {
        for val in self {
            val.search(search)?;
        }

        Found::No
    }
}

impl NodeSearcher for parser::DataType {
    fn search<'a>(&'a self, search: &mut NodeSearch<'a>) -> Found<()> {
        if !self.range.contains(&search.pos) {
            return Found::No;
        }

        let class = match project::PowerScriptType::new(&self) {
            project::PowerScriptType::Complex(name) => Some(
                search
                    .linter
                    .proj
                    .find_class(Some(search.linter.file), &name),
            ),
            _ => None,
        };

        search.nodes.push(Node::DataType(self, class));

        Found::Yes(())
    }
}

